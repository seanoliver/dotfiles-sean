{
  "mcpServers": {
    "day-one": {
      "command": "/usr/local/bin/dayone",
      "args": ["mcp"]
    }
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(open \"raycast://extensions/raycast/raycast/confetti\")",
      "mcp__serena__search_for_pattern",
      "mcp__serena__list_dir",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__find_symbol",
      "mcp__serena__find_file",
      "mcp__github__pull_request_read",
      "Bash(pnpm eslint:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:prettier:*)",
      "mcp__serena__initial_instructions",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__think_about_collected_information",
      "mcp__github__update_pull_request",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__list_network_requests",
      "mcp__chrome-devtools__click",
      "mcp__linear-server__list_teams",
      "mcp__linear-server__create_issue",
      "mcp__linear-server__update_issue",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(git log:*)",
      "mcp__notion-stdio__notion-search",
      "mcp__notion-stdio__notion-fetch",
      "Bash(echo:*)"
    ],
    "deny": [],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -f ~/.claude/SOUL.md ] && cat ~/.claude/SOUL.md || true"
          },
          {
            "type": "command",
            "command": "[ -f ~/.claude/skills/using-superpowers/SKILL.md ] && { echo '<EXTREMELY_IMPORTANT>'; echo 'You have superpowers. Below is the full content of your local using-superpowers skill — your introduction to using skills. For all other skills, use the Skill tool.'; echo; cat ~/.claude/skills/using-superpowers/SKILL.md; echo '</EXTREMELY_IMPORTANT>'; } || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          },
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date -u +%FT%TZ)\" --arg cwd \"$PWD\" 'if (.prompt | test(\"^/[a-zA-Z0-9_:-]+\")) then (.prompt | capture(\"^/(?<cmd>[a-zA-Z0-9_:-]+)\\\\s*(?<rest>.*)$\")) as $m | [$ts, $cwd, (\"slash:\" + $m.cmd), $m.rest] | @tsv else empty end' >> ~/.claude/skill-usage.tsv 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r --arg ts \"$(date -u +%FT%TZ)\" --arg cwd \"$PWD\" '[$ts, $cwd, (.tool_input.skill // \"\"), ((.tool_input.args // \"\") | tostring)] | @tsv' >> ~/.claude/skill-usage.tsv 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -z \"$f\" ] && exit 0; real=$(readlink -f \"$f\" 2>/dev/null); [ -z \"$real\" ] && exit 0; case \"$real\" in \"$HOME/dotfiles/\"*) ;; *) exit 0 ;; esac; rel=\"${real#$HOME/dotfiles/}\"; case \"$rel\" in *.env|*.env.*|.env|.env.*|*secret*|*Secret*|*SECRET*|*token*|*Token*|*TOKEN*|*credentials*|*Credentials*|*CREDENTIALS*|*password*|*Password*|*PASSWORD*|*.pem|*.PEM|*.key|*.KEY|*.p12|*.pfx|private/*|*/private/*|.private/*|*/.private/*|.aws/*|*/.aws/*|.ssh/*|*/.ssh/*) echo \"[$(date -u +%FT%TZ)] skip-secret-pattern: $rel\" >> \"$HOME/.claude/dotfiles-autocommit.log\"; exit 0 ;; esac; cd \"$HOME/dotfiles\" 2>/dev/null || exit 0; git add \"$real\" 2>/dev/null; if ! git diff --cached --quiet -- \"$real\" 2>/dev/null; then git commit -m \"dotfiles: auto-commit $rel\" -- \"$real\" 2>/dev/null && git push origin main 2>/dev/null; fi; } 2>>\"$HOME/.claude/dotfiles-autocommit.log\" || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-wrapper.sh"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "github@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "warp@claude-code-warp": true,
    "vercel@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "verbose": true,
  "preferredNotifChannel": "ghostty",
  "voiceEnabled": true
}
