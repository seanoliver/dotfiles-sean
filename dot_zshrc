# Initialize zoxide
eval "$(zoxide init zsh)"

# Set Cursor as default editor
export EDITOR="cursor --wait"

# NVM
export NVM_DIR="$HOME/.nvm"
  [ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
  [ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion

# PNPM
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# Ruby (optional)
export PATH="/opt/homebrew/opt/ruby/bin:/opt/homebrew/lib/ruby/gems/3.4.0/bin:$PATH"

# Powerlevel10k
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh

# Starship (Warp fallback)
eval "$(starship init zsh)"

# Plugins
[ -s "$HOME/.zsh/plugins/bd/bd.zsh" ] && source "$HOME/.zsh/plugins/bd/bd.zsh"
[ -s "$HOME/.zsh/plugins/alias-tips/alias-tips.plugin.zsh" ] && source "$HOME/.zsh/plugins/alias-tips/alias-tips.plugin.zsh"

# Aliases
alias ez='chezmoi edit ~/.zshrc'
alias sz='source ~/.zshrc'

alias cm='chezmoi'

alias ls='eza'                         # Modern replacement for ls
alias ll='eza -lah'                    # Long format, all files, human readable
alias lt='eza --tree'                  # Tree view

alias ..='cd ..'
alias ...='cd ../..'

alias j='z'                            # Jump to recently used directories (zoxide)
alias jh='zoxide query -l'             # List zoxide jump history
alias cdz='zoxide add $(pwd)'          # Manually add current dir to zoxide

alias f='fzf'                          # Fuzzy find anything
alias fh='history | fzf'               # Fuzzy search shell history

alias c='clear -r'
alias g='git'
alias gs='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gca='git commit -am'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gl='git log --oneline --graph --decorate'
alias gd='git diff | delta'           # Prettify git diff with delta

alias gmain='git checkout main && git pull'
alias gundo='git reset --soft HEAD~1'

alias npms='npm start'
alias npmi='npm install'
alias npmb='npm run build'

alias pnpmi='pnpm install'
alias pnpms='pnpm start'
alias pnpmd='pnpm dev'
alias pnpmb='pnpm build'
alias pnpmr='pnpm run'
alias pnpmt='pnpm test'
alias pnpml='pnpm lint'

alias ls='eza'
alias cd='z'
alias proj='cd ~/code && ls'

alias help='tldr'                      # Simplified man pages
alias man='tldr'                       # Override man with tldr (optional)
alias doc='tldr'                       # Another alias for consistency

alias cl='clear && printf "\e[3J"'     # Full terminal clear (scrollback too)
alias duh='du -sh * | sort -h'         # Show dir sizes
alias findbig='du -ah . | sort -rh | head -n 20' # Largest files
alias tree='eza --tree -L 2'           # Two-level dir tree
alias cat='bat'                        # Prettier cat
alias less='bat'                       # Prettier less (optional)

alias path='echo -e ${PATH//:/\\n}'
alias ip='curl ifconfig.me'           # Public IP address
alias now='date +"%T"'
alias nowdate='date +"%d-%m-%Y"'
alias ports='lsof -i -P -n | grep LISTEN'


