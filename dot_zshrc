# Load z (directory jumper)
. $(brew --prefix)/etc/profile.d/z.sh

# NVM
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && . "$NVM_DIR/bash_completion"

# PNPM
export PNPM_HOME="$HOME/Library/pnpm"
export PATH="$PNPM_HOME:$PATH"

# Ruby (optional)
export PATH="/opt/homebrew/opt/ruby/bin:/opt/homebrew/lib/ruby/gems/3.4.0/bin:$PATH"

# Powerlevel10k
[[ -f ~/.p10k.zsh ]] && source ~/.p10k.zsh
source /opt/homebrew/opt/powerlevel10k/powerlevel10k.zsh-theme

# Starship (Warp fallback)
eval "$(starship init zsh)"

# Plugins
[ -s "$HOME/.zsh/plugins/bd/bd.zsh" ] && source "$HOME/.zsh/plugins/bd/bd.zsh"
[ -s "$HOME/.zsh/plugins/alias-tips/alias-tips.plugin.zsh" ] && source "$HOME/.zsh/plugins/alias-tips/alias-tips.plugin.zsh"

# Aliases
alias ez='cursor ~/.zshrc'
alias sz='source ~/.zshrc'
alias c='clear -r'
alias g='git'
alias gs='git status'
alias ga='git add'
alias gaa='git add --all'
alias gc='git commit -m'
alias gca='git commit -am'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias gmain='git checkout main && git pull'
alias gundo='git reset --soft HEAD~1'
alias gr='git rebase'
alias gri='git rebase -i'
alias grih='git rebase -i HEAD~1'
alias gh='gh'
alias home='cd $HOME'
alias path='echo -e ${PATH//:/\\n}'
alias now='date +"%T"'
alias nowdate='date +"%d-%m-%Y"'

# Secrets (injected at apply time)
export OPENAI_API_KEY="{{ (secret \"keyring:chezmoi/openai_api_key\") }}"
export SUPABASE_ACCESS_TOKEN="{{ (secret \"keyring:chezmoi/supabase_access_token\") }}"

# Machine info
echo "Loaded by chezmoi for {{ .os }} on {{ .hostname }} (user: {{ .username }})"
